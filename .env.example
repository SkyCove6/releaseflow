# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<project-id>/settings/api-keys/legacy
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Inngest ─────────────────────────────────────────────────────────────────
# Get these from: https://app.inngest.com/settings/keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from: https://dashboard.stripe.com/webhooks (after creating webhook endpoint)
STRIPE_WEBHOOK_SECRET=
# Price IDs from: https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_LABEL=
